---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

const galleries = [
  { title: 'Portrait', href: '/portraits', description: 'Portrait & Editorial' },
  { title: 'Landscape', href: '/landscapes', description: 'Nature & Horizon' },
  { title: 'Street', href: '/street', description: 'Urban & City' },
];

// Read random background from landscapes folder with eager: true
const imageFiles = import.meta.glob('/src/assets/landscapes/*.{jpg,JPG,jpeg,JPEG,png,PNG,webp,WEBP,avif,AVIF}', { eager: true });
const images = Object.values(imageFiles).map((img: any) => img.default);
const randomBg = images.length > 0 ? images[Math.floor(Math.random() * images.length)] : null;
---

<Layout title="LIYUAN WEI | Photographer">
  <!-- Home Page with Ambient Glassmorphism -->
  <main class="relative min-h-screen w-full overflow-hidden bg-black">
    <!-- Layer 1: Background Image (blurred) -->
    {randomBg && (
      <Image
        src={randomBg}
        alt="Ambient Background"
        class="absolute inset-0 w-full h-full object-cover scale-110 z-0"
        loading="eager"
      />
    )}

    <!-- Layer 2: Glassmorphism Overlay -->
    <div class="absolute inset-0 bg-black/60 backdrop-blur-3xl z-10"></div>

    <!-- Layer 3: Content -->
    <div class="relative z-20 flex flex-col items-center justify-center min-h-screen w-full px-6">
      <div class="text-center">
        <p class="subheading text-neutral-400 mb-4">Photography Portfolio</p>
        <h1 class="font-display text-6xl md:text-8xl lg:text-9xl font-medium leading-[0.9] mb-8 text-white">
          LIYUAN WEI
        </h1>
        <p class="text-lg md:text-xl text-neutral-300 max-w-sm mx-auto font-light leading-relaxed mb-12">
          {/* Portraits & Landscape description removed */}
        </p>

        <!-- Gallery Links -->
        <div class="flex flex-col md:flex-row gap-8 md:gap-12 justify-center">
          {galleries.map((gallery) => (
            <a href={gallery.href} class="group">
              <span class="subheading block mb-2 text-neutral-300">{gallery.title}</span>
              <span class="text-sm text-neutral-500 block group-hover:opacity-60 transition-opacity">
                {gallery.description}
              </span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="px-6 lg:px-20 py-16 border-t border-white/10">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <p class="subheading text-neutral-500">&copy; 2026 LIYUAN WEI</p>
      <div class="flex gap-8">
        <a href="#" class="subheading text-neutral-500 hover:text-white transition-colors">Instagram</a>
        <a href="#" class="subheading text-neutral-500 hover:text-white transition-colors">Email</a>
      </div>
    </div>
  </footer>
</Layout>