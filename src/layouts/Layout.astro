---
// FloatingNav.astro - 极简高级感悬浮导航球 + 全屏菜单
import FloatingNav from '../components/FloatingNav.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const { pathname } = Astro.url;
const currentPath = pathname.replace('/', '');
---

<!doctype html>
<html lang="zh-CN" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Space+Mono:wght@400;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <meta name="description" content="LIYUAN WEI - Photographer Portfolio" />
</head>
<body class="bg-[#0A0A0A] text-neutral-50">
  <!-- Fixed Navigation -->
  <nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 px-6 lg:px-12 py-6 flex justify-between items-center bg-transparent border-transparent transition-all duration-500 ease-in-out">
    <a href="/" class="font-display text-xl tracking-wide hover:opacity-60 transition-opacity">LIYUAN WEI</a>
    <div class="flex gap-6 lg:gap-10 items-center">
      <a href="/portraits" class={`font-display tracking-widest text-xs hover:opacity-60 transition-opacity ${currentPath === 'portraits' ? 'opacity-40' : ''}`}>PORTRAITS</a>
      <a href="/landscapes" class={`font-display tracking-widest text-xs hover:opacity-60 transition-opacity ${currentPath === 'landscapes' ? 'opacity-40' : ''}`}>LANDSCAPES</a>
      <a href="/street" class={`font-display tracking-widest text-xs hover:opacity-60 transition-opacity ${currentPath === 'street' ? 'opacity-40' : ''}`}>STREET</a>
    </div>
  </nav>

  <main id="page-content" class="pt-20">
    <slot />
  </main>

  <FloatingNav />

<script>
  const mainNav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      mainNav.classList.add('bg-black/60', 'backdrop-blur-md', 'border-b', 'border-white/10');
    } else {
      mainNav.classList.remove('bg-black/60', 'backdrop-blur-md', 'border-b', 'border-white/10');
    }
  });
</script>
</body>
</html>

<style is:global>
  :root {
    --color-gold: #C9A227;
  }

  .font-display {
    font-family: 'Playfair Display', serif;
  }

  .subheading {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
</style>